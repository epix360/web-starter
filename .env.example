# ============================================================
# SITE
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="My Site"

# ============================================================
# SANITY (required)
# ============================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only read token (for draft previews & private content)
SANITY_API_READ_TOKEN=
# Server-only write token (Editor role) — only needed to run `npm run seed`
SANITY_API_WRITE_TOKEN=
# Used to authenticate the /api/revalidate webhook from Sanity
SANITY_REVALIDATE_SECRET=

# ============================================================
# PLAUSIBLE (required)
# ============================================================
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional: only set if self-hosting Plausible
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js

# ============================================================
# SUPABASE (optional - delete if unused)
# ============================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# RESEND (optional - delete if unused)
# ============================================================
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Hello <hello@yourdomain.com>"

# ============================================================
# TALLY (optional - delete if unused)
# ============================================================
# Tally is client-side embed; only needed if using the webhook handler
# TALLY_WEBHOOK_SECRET=
