    "@sanity/vision": "^3.57.0",
    "next": "^15.0.0",
    "next-sanity": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanity": "^3.57.0",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
